{
  "name": "garden-core",
  "private": true,
  "version": "1.1.0",
  "funding": "https://github.com/sponsors/GratiaOS",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:server": "pnpm --filter @gratiaos/server dev",
    "dev:playground": "pnpm --filter playground dev",
    "start:prod": "cross-env NODE_ENV=production dotenv -e server/.env.production -- pnpm --filter @gratiaos/server start",
    "build": "pnpm -r build",
    "lint": "echo 'lint TBA' && exit 0",
    "changeset": "changeset",
    "release": "changeset version && pnpm -r build && pnpm -r publish --access public"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "^10.0.1",
      "glob": "^11.0.0",
      "rimraf": "^6.0.1",
      "js-yaml": "^4.1.1",
      "ajv": "^8.17.1",
      "@isaacs/brace-expansion": "^4.0.0",
      "semver": "^7.7.4"
    },
    "peerDependencyRules": {
      "ignoreMissing": [],
      "allowedVersions": {
        "eslint-plugin-react-hooks>eslint": "^10"
      }
    }
  }
}
